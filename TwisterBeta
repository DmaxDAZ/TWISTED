local function randomString(num)
    if not num then return end
	local length = math.random(num)
	local array = {}
	for i = 1, length do
		array[i] = string.char(math.random(32, 126))
	end
	return table.concat(array)
end

local function collectProbe(prompt)
    local prompt = prompt
    if prompt and not probeHolding then
        fireProximityPromptSafe(prompt)
        if VirtualInputManager and not probeHolding then
            probeHolding = true
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(2)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
            probeHolding = false
        end
        task.wait(0.5)
    end
end

