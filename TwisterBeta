local function StopTrucking()
    if TruckLoopThread then
        task.cancel(TruckLoopThread)
        TruckLoopThread = nil
    end
    if AntiflingConn then
        AntiflingConn:Disconnect()
        AntiflingConn = nil
    end
    if lastConn then
        lastConn:Disconnect()
        lastConn = nil
    end
    ToDo = "Idle"
    if holding then
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.R, false, game)
        holding = false
    end
    if player.PlayerGui:FindFirstChild("TripDetails") then
        local cancel = player.PlayerGui:WaitForChild("details"):WaitForChild("interaction"):FindFirstChild("cancel")
        if cancel then
            CleverClick(cancel, false)
        end
    end
end

local function StartTrucking()
    TruckLoopThread = task.spawn(function()
        while true do 
            task.wait()

                if lastConn then
                    lastConn:Disconnect()
                    lastConn = nil
                end

                if humanoid.Health == 0 then
                    local respawngui = player.PlayerGui:FindFirstChild("RespawnGUI")
                    if respawngui then
                        local respawn = respawngui:FindFirstChild("respawn"):FindFirstChild("button")
                        if respawn then
                            CleverClick(respawn, false)
                        end
                    end
                end

                if not char or not char.Parent then continue end
                if not humanoid or humanoid.Health <= 0 then continue end
                if not root then continue end

                local cameraPos = root.Position + Vector3.new(0, 100, 0)
                Camera.CFrame = CFrame.lookAt(cameraPos, root.Position)
        
                local name, cf, dist = GetNearestZone()
                
                if cf then
                    J_TruckCF = cf
                end
        
                if ToDo == "Idle" then
                    local cf = J_TruckCF
                    if cf then
                        ToDo = "MovingToZone"
                        Linear(root, cf, 550, function()
                            root.CFrame = cf
                            root.Velocity = Vector3.zero
                            task.wait(0.5)
                            ToDo = "GettingTask"
                        end)
                    end
                end
        
                if ToDo == "GettingTask" then
                    local prompt = GetTruckJobPrompt()

                    if not prompt then
                        ToDo = "Idle"
                    end
        
                    if prompt and not player.PlayerGui:FindFirstChild("TruckingOffers") then
                        repeat
                        fireProximityPromptSafe(prompt)
                        warn(prompt:GetFullName())
                        task.wait()
                        until player.PlayerGui:FindFirstChild("TruckingOffers")
                        task.wait(1)
        
                        local best = GetBestOfferTruck()
                        if best and player.PlayerGui:FindFirstChild("TruckingOffers") and not player.PlayerGui:FindFirstChild("TripDetails") then
                            repeat
                            CleverClick(best)
                            task.wait(0.25)
                            until player.PlayerGui:FindFirstChild("TripDetails")
                            ToDo = "WaitingForCar"
                        end
                    end
                end
        
                if ToDo == "WaitingForCar" then
                    local car = workspace.player_related.cars:FindFirstChild(player.UserId)
        
                    if car and not humanoid.Sit then
                        local seat = car:FindFirstChild("seats") and car.seats:FindFirstChild("driver")
                        if seat then
                            Linear(root, seat, 550)
                        end
                    end
        
                    if humanoid.Sit then
                        task.wait(0.25)
                        ToDo = "TeleportUp"
                    end
                end
        
                if ToDo == "TeleportUp" then
                    local car = workspace.player_related.cars:FindFirstChild(player.UserId)
                    local primary = car and (car.PrimaryPart or car:FindFirstChildWhichIsA("BasePart"))
        
                    if primary then
                        primary.CFrame = primary.CFrame * CFrame.new(0, 525, 0)
                        task.wait(0.2)
                        ToDo = "GoingToTarget"
                    end
                end
        
                if ToDo == "GoingToTarget" then
                    local target = GetTrailerBox()
                    local car = workspace.player_related.cars:FindFirstChild(player.UserId)
                    local primary = car and (car.PrimaryPart or car:FindFirstChildWhichIsA("BasePart"))
        
                    if target and primary then
                        ToDo = "Driving"
                        if driving then continue end
                        driving = true
                        task.spawn(function()
                            AntiflingConn = RunService.Heartbeat:Connect(function()
                                car:WaitForChild("_trailer").PrimaryPart.CFrame = primary.CFrame
                                car:WaitForChild("_trailer").PrimaryPart.Velocity = Vector3.zero
        
                                task.spawn(function()
                                    for _, v in ipairs(car:WaitForChild("wheels"):GetChildren()) do
                                        if v:IsA("Model") then
                                            if v.PrimaryPart then
                                                v.PrimaryPart.CFrame = primary.CFrame
                                                v.PrimaryPart.Velocity = Vector3.zero
                                            end
                                        end
                                    end
                                end)
                            end)
                        end)
                        Linear(primary, target.CFrame * CFrame.new(0, 525, 0), 90, function()
                            Linear(primary, target.CFrame * CFrame.new(0, 0, 0), 550, function()
                            if AntiflingConn then
                            AntiflingConn:Disconnect()
                            AntiflingConn = nil
                            end
                            end)

                            car:WaitForChild("_trailer").PrimaryPart.CFrame = primary.CFrame
                            car:WaitForChild("_trailer").PrimaryPart.Velocity = Vector3.zero

                            task.spawn(function()
                                for _, v in ipairs(car:WaitForChild("wheels"):GetChildren()) do
                                    if v:IsA("Model") then
                                        if v.PrimaryPart then
                                            v.PrimaryPart.CFrame = primary.CFrame
                                            v.PrimaryPart.Velocity = Vector3.zero
                                        end
                                    end
                                end
                            end)

                            driving = false
                            Last = target
                            ToDo = "Finishing"
                        end)
                    end
                end
        
                if ToDo == "Finishing" then
                    local promptGui = player.PlayerGui:FindFirstChild("prompt")
                    local car = workspace.player_related.cars:FindFirstChild(player.UserId)
                    local primary = car and (car.PrimaryPart or car:FindFirstChildWhichIsA("BasePart"))
        
                    if promptGui then
                        task.spawn(function()
                            if not lastConn then
                            lastConn = RunService.Heartbeat:Connect(function()
                                if not car.Parent or not primary.Parent then 
                                    if lastConn then lastConn:Disconnect() end
                                    return 
                                end
                                
                                if not Last then return end
                                primary.Velocity = Vector3.zero
                                Linear(primary, Last.CFrame * CFrame.new(0, 0, 0), 550, function ()
                                    primary.Velocity = Vector3.zero
                                    primary.CFrame = Last.CFrame * CFrame.new(0, 0, 0)
                                end)
                                
                                local trailer = car:FindFirstChild("_trailer")
                                if trailer and trailer.PrimaryPart then
                                    trailer.PrimaryPart.Velocity = Vector3.zero
                                    trailer.PrimaryPart.CFrame = primary.CFrame * CFrame.new(0,-4, -5)
                                end
                            end)
                        end
                        end)
        
                        local key = promptGui:WaitForChild("main"):FindFirstChild("keybind")
                        if key then
                            if VirtualInputManager and not holding then
                                holding = true
                                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.R, false, game)
                                task.wait(2)
                                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.R, false, game)
                                holding = false
                            end
                        end
                    end
        
                    if not workspace.player_related.cars:FindFirstChild(player.UserId) then
                        ToDo = "Idle"
                        if lastConn then
                            lastConn:Disconnect()
                            lastConn = nil
                        end

                        if AntiflingConn then
                            AntiflingConn:Disconnect()
                            AntiflingConn = nil
                        end
                    end
                end
            if not T_TJob then 
                break 
            end
        end
    end)
end

local function getWindTier(winds)
    if winds <= 85 then return 0
    elseif winds <= 110 then return 1
    elseif winds <= 130 then return 2
    elseif winds <= 150 then return 3
    elseif winds <= 175 then return 4
    else return 5 end
end

