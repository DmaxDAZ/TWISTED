local function StartTrucking()
    local already = false
    StopTrucking()
    task.wait(0.1)
    isTrucking = true
    local cameraPos = root.Position + Vector3.new(0, 10, 0)
    local tween = TweenService:Create(Camera, TweenInfo.new(0.35, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {CFrame = CFrame.lookAt(cameraPos, root.Position)})
    tween:Play()
    player.CameraMinZoomDistance = 9
    player.CameraMaxZoomDistance = 10

    TruckLoopThread = task.spawn(function()
        while isTrucking and T_TJob do 
            task.wait(0.1)

            char = player.Character
            humanoid = char and char:FindFirstChildOfClass("Humanoid")
            root = char and char:FindFirstChild("HumanoidRootPart")

            local respawngui = player.PlayerGui:FindFirstChild("RespawnGUI")
            if respawngui then
                local btn = respawngui:FindFirstChild("button", true)
                if btn then
                    CleverClick(btn, false)
                    task.wait(0.5)
                    continue
                end
            end

            if not (char and humanoid and root and humanoid.Health > 0) then 
                continue 
            end

            if ToDo == "Idle" then
                local name, cf = GetNearestZone()
                if cf then
                    table.insert(VisitedZones, name)
                    ToDo = "MovingToZone"
                    local cameraPos = root.Position + Vector3.new(0, 10, 0)
                    local tween = TweenService:Create(Camera, TweenInfo.new(0.15, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {CFrame = CFrame.lookAt(cameraPos, root.Position)})
                    tween:Play()
                    task.wait(0.5)
                    Linear(root, cf, 550, function()
                        if not isTrucking then return end
                        root.CFrame = cf
                        task.wait(0.5)
                        ToDo = "GettingTask"
                    end)
                end

            elseif ToDo == "GettingTask" then
                if player.PlayerGui:FindFirstChild("TripDetails") then
                    ToDo = "WaitingForCar"
                    continue
                end
            
                local prompt = GetTruckJobPrompt()
                if not prompt then 
                    ToDo = "Idle" 
                    continue 
                end
            
                local startTime = tick()

                repeat
                    fireProximityPromptSafe(prompt)
                    warn(prompt:GetFullName())
                    task.wait(0.2)
                until player.PlayerGui:FindFirstChild("TruckingOffers") or (tick() - startTime > 5)
            
                if not player.PlayerGui:FindFirstChild("TruckingOffers") then
                    ToDo = "Idle"
                    continue
                end
            
                task.wait(1)
            
                local offers = player.PlayerGui:FindFirstChild("TruckingOffers")
                if offers then
                    local best = GetBestOfferTruck()
                    if best then
            
                        local startSelect = tick()
                        repeat
                            CleverClick(best)
                            warn(best:GetFullName())
                            task.wait(0.2)
                        until player.PlayerGui:FindFirstChild("TripDetails") or (tick() - startSelect > 5)
            
                        if player.PlayerGui:FindFirstChild("TripDetails") then
                            ToDo = "WaitingForCar"
                        else
                            ToDo = "Idle"
                        end
            
                    else
                        ToDo = "Idle"
                    end
                else
                    ToDo = "Idle"
                    continue
                end

            elseif ToDo == "WaitingForCar" then
                local car = workspace.player_related.cars:FindFirstChild(player.UserId)
                if car and not humanoid.Sit then
                    warn(car:GetFullName())
                    local seat = car:FindFirstChild("driver", true)
                    if seat then
                        Linear(root, seat.CFrame * CFrame.new(0, 0, 0), 550, function()
                            root.Velocity = Vector3.zero
                            root.RotVelocity = Vector3.zero
                            root.CFrame = seat.CFrame
                        end)
                    end
                end

                if humanoid.Sit then
                    task.wait(0.25)
                    ToDo = "TeleportUp"
                end

            elseif ToDo == "TeleportUp" then
                local car = workspace.player_related.cars:FindFirstChild(player.UserId)
                local primary = car and (car.PrimaryPart or car:FindFirstChildWhichIsA("BasePart"))
                
                if primary and humanoid.Sit then
                    task.wait(0.25)
                    primary.Velocity = Vector3.zero
                    primary.RotVelocity = Vector3.zero
                    primary.CFrame = primary.CFrame * CFrame.new(0, 525, 0)
                    task.wait(0.25)
                    ToDo = "GoingToTarget"
                    if not already then
                        already = true
                        local cameraPos = root.Position + Vector3.new(0, 15, 0)
                        local tween = TweenService:Create(Camera, TweenInfo.new(0.15, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {CFrame = CFrame.lookAt(cameraPos, root.Position)})
                        tween:Play()
                        player.CameraMinZoomDistance = 14
                        player.CameraMaxZoomDistance = 15
                    end
                end

            elseif ToDo == "GoingToTarget" then
                local target = GetTrailerBox()
                local car = workspace.player_related.cars:FindFirstChild(player.UserId)
                local primary = car and (car.PrimaryPart or car:FindFirstChildWhichIsA("BasePart"))

                if target and primary then
                    ToDo = "Driving"

                    task.spawn(function()
                        lastConn = RunService.Heartbeat:Connect(function()
                            if not isTrucking or ToDo ~= "Driving" then return end
                            local trailer = car:FindFirstChild("_trailer")
                            if trailer and trailer.PrimaryPart then
                                trailer.PrimaryPart.Velocity = Vector3.zero
                                trailer.PrimaryPart.RotVelocity = Vector3.zero
                                trailer.PrimaryPart.CFrame = primary.CFrame
    
                                task.spawn(function()
                                local wheels = car:FindFirstChild("wheels")
                                if not wheels then return end
                                    for _, v in ipairs(wheels:GetChildren()) do
                                        if v:IsA("Model") then
                                            if v.PrimaryPart then
                                                v.PrimaryPart.Velocity = Vector3.zero
                                                v.PrimaryPart.RotVelocity = Vector3.zero
                                                v.PrimaryPart.CFrame = primary.CFrame
                                            end
                                        end
                                    end
                                end)
                            end
                        end)
                    end)

                    Linear(primary, target * CFrame.new(0, 525, 0), 90, function()
                        if not isTrucking then return end
                        Linear(primary, target, 550, function()
                            Last = target
                            ToDo = "Finishing"
                        end)
                    end)
                end

            elseif ToDo == "Finishing" then
                local car = workspace.player_related.cars:FindFirstChild(player.UserId)
                local primary = car and (car.PrimaryPart or car:FindFirstChildWhichIsA("BasePart"))
                if not car then
                    table.clear(VisitedZones)
                    SafeDisconnect(lastConn)
                    SafeDisconnect(agaConn)
                    ToDo = "Idle"
                    already = false
                    continue
                end

                task.spawn(function()
                    agaConn = RunService.Heartbeat:Connect(function()
                        if not isTrucking or ToDo ~= "Finishing" or not Last then return end

                        if primary then
                            primary.Velocity = Vector3.zero
                            primary.RotVelocity = Vector3.zero
                            primary.CFrame = Last * CFrame.new(0, 0, 0)
                        end

                        local trailer = car:FindFirstChild("_trailer")
                        if trailer and trailer.PrimaryPart then
                            trailer.PrimaryPart.Velocity = Vector3.zero
                            trailer.PrimaryPart.RotVelocity = Vector3.zero
                            trailer.PrimaryPart.CFrame = primary.CFrame * CFrame.new(0,-4, -5)
                        end

                        task.spawn(function()
                            local wheels = car:FindFirstChild("wheels")
                            if not wheels then return end
                            for _, v in ipairs(wheels:GetChildren()) do
                                if v:IsA("Model") then
                                    if v.PrimaryPart then
                                        v.PrimaryPart.Velocity = Vector3.zero
                                        v.PrimaryPart.RotVelocity = Vector3.zero
                                        v.PrimaryPart.CFrame = primary.CFrame
                                    end
                                end
                            end
                        end)
                    end)
                end)

                local promptGui = player.PlayerGui:FindFirstChild("prompt")
                if promptGui then warn(promptGui:GetFullName()) end
                if promptGui and not holding then
                    holding = true
                    task.spawn(function()
                        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.R, false, game)
                        task.wait(2.5)
                        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.R, false, game)
                        holding = false
                    end)
                end
            end
        end
    end)
end

local function getWindTier(winds)
    if winds <= 35 then return 0
    elseif winds <= 80 then return 1
    elseif winds <= 100 then return 2
    elseif winds <= 120 then return 3
    elseif winds <= 140 then return 4
    else return 5 end
end

