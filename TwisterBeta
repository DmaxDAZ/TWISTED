local probe = false
local currentProbe = nil

local probee = Tabs.Main:CreateToggle("Probe", {Title = "Toggle Auto Collect Probes", Default = false })

probee:OnChanged(function(bool)
    probe = bool

    if bool then
        task.spawn(function()
            while probe do
                root.Anchored = false
                if not currentProbe or not currentProbe.Parent then
                    currentProbe = nil
                    
                    for _, v in ipairs(workspace.player_related.probes:GetChildren()) do
                        if v:IsA("Model") and v.Name == tostring(game.Players.LocalPlayer.UserId) then
                            currentProbe = v
                            break
                        end
                    end
                end

                if currentProbe and currentProbe.Parent then
                    local isDone = false
                    
                    Linear(root, currentProbe:GetPivot(), 550, function()
                        task.wait(0.15)
                        root.Anchored = true
                        root.AssemblyLinearVelocity = Vector3.zero
                        root.CFrame = root.CFrame * CFrame.new(0,4,0)
                        local promptPart = currentProbe:FindFirstChild("PromptPart")
                        if promptPart then
                            local prompt = promptPart:FindFirstChild("Prompt")
                            if prompt then
                                collectProbe(prompt)
                            end
                        end
                        isDone = true
                        root.Anchored = false
                    end)

                    repeat 
                        task.wait() 
                        root.AssemblyLinearVelocity = Vector3.zero
                        root.Anchored = true
                    until isDone or not currentProbe or not currentProbe.Parent or not probe
                    
                    currentProbe = nil
                else
                    task.wait()
                end
                
                task.wait()
            end
        end)
    else
        root.Anchored = false
        CancelLinear()
        currentProbe = nil
    end
end)


