local function GetTruckJobPrompt()
    local gridDamage = workspace:WaitForChild("map_related"):WaitForChild("grid_damage")

    for _, grid in ipairs(gridDamage:GetChildren()) do
        if grid:IsA("Folder") or grid:IsA("Model") then

            local trucking = grid:FindFirstChild("Trucking Warehouse") or grid:FindFirstChild("Trucking Grain") or grid:FindFirstChild("Trucking Logging")
            if trucking then
                local job = trucking:FindFirstChild("job")

                if job then
                    local hitbox = job:FindFirstChild("job_hitbox")
                    if hitbox and (hitbox.Position - root.Position).Magnitude < 25 then
                        local prompt = hitbox:FindFirstChildWhichIsA("ProximityPrompt")
                        if prompt then
                            return prompt
                        end
                    end
                end

            end

        end
    end

    return nil
end

local function GetTrailerBox()
    if not root then return nil end

    local selectedBox = nil
    local farthestDistance = 500

    for _, box in ipairs(workspace:FindFirstChild("Camera"):GetChildren()) do
        if box:IsA("Part") and box.Name == "trailer_hitbox" then
            local dist = (box.Position - root.Position).Magnitude

            if dist > 500 and dist > farthestDistance then
                farthestDistance = dist
                selectedBox = box.CFrame
            end
        end
    end

    if not selectedBox then
        local job = player:FindFirstChild("ActiveTruckJob")
        if job then
            selectedBox = job.Finish:GetAttribute("ClientCF")
        end
    end

    return selectedBox
end

local function parseNumber(str)
    if not str then return 0 end

    local cleaned = tostring(str):gsub("[^%d]", "")
    return tonumber(cleaned) or 0
end

local function GetBestOfferTruck()
    local bestButton = nil
    local bestValue = -1
    
    local startTime = tick()
    local searchDuration = 2.5

    repeat task.wait(0.05)
        local gui = player.PlayerGui:FindFirstChild("TruckingOffers")
        if gui and gui:FindFirstChild("jobs") then
            local scroll = gui.jobs.main.scroll
            local offers = scroll:GetChildren()

            for _, v in ipairs(offers) do
                if v:IsA("ImageButton") and v.Visible then
                    local profitLabel = v:FindFirstChild("profit", true)
                    
                    if profitLabel and profitLabel.Text ~= "" then
                        local value = parseNumber(profitLabel.Text)
                        
                        if value > bestValue then
                            bestValue = value
                            bestButton = v
                        end
                    end
                end
            end
        end

        if bestValue == -1 then 
            task.wait(0.2) 
        end
        
    until bestValue > 0 or (tick() - startTime) > searchDuration

    return bestButton, bestValue
end

local function CleverClick(target, hold, duration)
    if not target then return end

    local GuiService = game:GetService("GuiService")
    local VIM = game:GetService("VirtualInputManager")

    hold = hold or false
    duration = duration or 0.1

    pcall(function()
        GuiService.SelectedObject = target
        task.wait()

        if hold then
            VIM:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
            task.wait(duration)
            VIM:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
        else
            VIM:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
            task.wait(0.05)
            VIM:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
        end

        GuiService.SelectedObject = nil
    end)

    pcall(function()
        if getconnections then
            for _, ev in ipairs({target.MouseButton1Down, target.MouseButton1Click, target.Activated}) do
                for _, conn in ipairs(getconnections(ev) or {}) do
                    if type(conn) == "table" and conn.Function then
                        conn.Function()
                    elseif type(conn) == "userdata" and conn.Fire then
                        conn:Fire()
                    end
                end
            end
        end
    end)
end

local function GetNearestZone()
    if not root then return nil end

    local closestCF = nil
    local closestName = nil
    local shortestDistance = math.huge
    local foundAny = false

    for name, cf in pairs(Zones) do
        if not table.find(VisitedZones, name) then
            foundAny = true
            local dist = (root.Position - cf.Position).Magnitude

            if dist < shortestDistance and dist > 50 then
                shortestDistance = dist
                closestCF = cf
                closestName = name
            end
        end
    end

    if not foundAny then
        table.clear(VisitedZones)
        return GetNearestZone()
    end

    return closestName, closestCF, shortestDistance
end

