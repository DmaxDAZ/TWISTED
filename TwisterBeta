task.spawn(function()
    while true do
        task.wait(0.3)
        if selectedPlayer then
            local targetPlr = game.Players:FindFirstChild(selectedPlayer)
            local ui = PlayerUI[selectedPlayer]
            
            if targetPlr and ui then
                local char = targetPlr.Character
                local rootPart = char and char:FindFirstChild("HumanoidRootPart")
                local hum = char and char:FindFirstChild("Humanoid")
                
                local carCount = 0
                local carNamesList = "None"
                
                local inv = targetPlr:FindFirstChild("player_inv")
                if inv then
                    local cars = inv:GetChildren() 
                    carCount = #cars
                    
                    if carCount > 0 then
                        local namesTable = {}
                        for _, carFolder in ipairs(cars) do
                            local realName = carFolder:GetAttribute("vehicle_name") or carFolder.Name
                            table.insert(namesTable, "🚗 " .. realName)
                        end
                        carNamesList = table.concat(namesTable, "\n")
                    end
                else
                    carNamesList = "Searching for player_inv..."
                end
                
                local pData = {
                    "- [ Player Status ] -",
                    "-Status: " .. (hum and (hum.Health > 0 and "Alive" or "Dead") or "Unknown"),
                    "-Health: " .. (hum and math.floor(hum.Health) or "0") .. "/" .. (hum and math.floor(hum.MaxHealth) or "0"),
                    "-Distance: " .. (rootPart and root and string.format("%.1f", (rootPart.Position - root.Position).Magnitude) or "0") .. " studs",
                    "",
                    "- [ Car Inventory ] -",
                    "Total Cars: " .. carCount,
                    carNamesList
                }
                
                ui:SetValue(table.concat(pData, "\n"))
            end
        end
    end
end)

